{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["esnext"],
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "noEmit": false,
    "outDir": "dist/worker",
    "rootDir": ".",
    "module": "CommonJS",
    "moduleResolution": "node"
  },
  "include": [
    "types/worker-globals.d.ts",
    "app/worker-env.ts",
    "app/worker.ts",
    "db.ts",
    "app/lib/jobs/**/*.ts",
    "app/lib/scrapeDiscountsSale.ts",
    "app/models/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
